[Unit]
Description=Annotation web app
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/opt/research-agent/scripts/web-start.sh
ExecStop=/usr/bin/docker stop research-agent-web
Restart=on-failure
RestartSec=30

LoadCredentialEncrypted=op-token:/etc/research-agent/op-token
LoadCredentialEncrypted=github-pat:/etc/research-agent/github-pat

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
